@if (Fields.Count > 0)
{
    <dl class="structured-fields">
        @foreach (ShowcaseResultField field in Fields)
        {
            <div>
                <dt>@Name(field)</dt>
                <dd class="@(field.IsCode ? "mono" : null)">@(field.Value ?? "null")</dd>
            </div>
        }
    </dl>
}

@code {
    [Parameter]
    public IReadOnlyList<ShowcaseResultField> Fields { get; set; } = Array.Empty<ShowcaseResultField>();

    [Parameter]
    public IShowcaseText? Text { get; set; }

    [Parameter]
    public string ResourceNamespace { get; set; } = string.Empty;

    private string Name(ShowcaseResultField field) => field.LocalizeName && Text is not null
        ? Text.GetText(ResourceNamespace, field.Name)
        : field.Name;
}
