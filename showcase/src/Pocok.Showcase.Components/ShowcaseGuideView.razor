<section class="guide" aria-label="Guide">
    @foreach (ShowcaseGuideSection guideSection in Guide.Sections.Take(PrimarySectionCount))
    {
        <details class="panel collapsible-support guide-primary" open>
            <summary>@Text.GetText(ResourceNamespace, guideSection.TitleKey)</summary>
            <div class="collapsible-support-content">
                <ShowcaseGuideSectionView Section="guideSection"
                                          Snippets="Guide.Snippets"
                                          Text="Text"
                                          ResourceNamespace="@ResourceNamespace"
                                          ShowTitle="false"
                                          Embedded="true" />
            </div>
        </details>
    }
    @if (Guide.Sections.Count > PrimarySectionCount)
    {
        <details class="guide-more">
            <summary>@MoreLabel</summary>
            <div class="guide-more-content">
                @foreach (ShowcaseGuideSection guideSection in Guide.Sections.Skip(PrimarySectionCount))
                {
                    <ShowcaseGuideSectionView Section="guideSection"
                                              Snippets="Guide.Snippets"
                                              Text="Text"
                                              ResourceNamespace="@ResourceNamespace"
                                              Compact="true" />
                }
            </div>
        </details>
    }
</section>

@code {
    private const int PrimarySectionCount = 2;

    [Parameter, EditorRequired] public ShowcaseGuide Guide { get; set; } = ShowcaseGuide.Empty;
    [Parameter, EditorRequired] public IShowcaseText Text { get; set; } = default!;
    [Parameter, EditorRequired] public string ResourceNamespace { get; set; } = string.Empty;
    [Parameter] public string MoreLabel { get; set; } = "More guidance";
}
