@if (TipKeys.Count > 0)
{
    <aside class="tip-panel">
        <strong>@Title</strong>
        <ul>
            @foreach (string key in TipKeys)
            {
                <li>@Text.GetText(ResourceNamespace, key)</li>
            }
        </ul>
    </aside>
}

@code {
    [Parameter] public string Title { get; set; } = "Tip";
    [Parameter] public IReadOnlyList<string> TipKeys { get; set; } = Array.Empty<string>();
    [Parameter, EditorRequired] public IShowcaseText Text { get; set; } = default!;
    [Parameter, EditorRequired] public string ResourceNamespace { get; set; } = string.Empty;
}
