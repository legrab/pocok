@page "/"
@inject ShowcasePackageCatalog PackageCatalog
@inject ShowcaseSliceCatalog SliceCatalog
@inject IShowcaseText Text

<PageTitle>@Text.GetText("shell", "App.Title")</PageTitle>

<section class="hero">
    <div>
        <p class="eyebrow">@Text.GetText("shell", "Home.Eyebrow")</p>
        <h1>@Text.GetText("shell", "Home.Title")</h1>
        <p class="hero-copy">@Text.GetText("shell", "Home.Intro")</p>
    </div>
    <div class="hero-actions">
        <a class="button-link" href="@FeaturedSlicePath">@Text.GetText("shell", "Home.StartAction")</a>
        <a class="button-link secondary-link" href="/system">@Text.GetText("shell", "Home.SystemAction")</a>
    </div>
</section>

<section class="metric-grid" aria-label="@Text.GetText("shell", "Home.States")">
    <div class="metric"><strong>@PackageCatalog.Packages.Count</strong><span>@Text.GetText("shell", "Home.Known")</span></div>
    <div class="metric"><strong>@SliceCatalog.Installed.Count</strong><span>@Text.GetText("shell", "Home.Available")</span></div>
    <div class="metric"><strong>@PlannedCount</strong><span>@Text.GetText("shell", "Home.Planned")</span></div>
    <div class="metric"><strong>@PackageCatalog.Packages.Count(package => package.State == "Active")</strong><span>@Text.GetText("shell", "Package.Active")</span></div>
    <div class="metric"><strong>@PackageCatalog.Packages.Count(package => package.State == "Experimental")</strong><span>@Text.GetText("shell", "Package.Experimental")</span></div>
    <div class="metric"><strong>@SliceCatalog.Installed.Count / @PackageCatalog.Packages.Count</strong><span>@Text.GetText("shell", "Home.Loaded")</span></div>
</section>

<section class="start-panel panel">
    <p class="eyebrow">@FeaturedSlice.Descriptor.PackageId</p>
    <h2>@Text.GetText("shell", "Home.StartTitle")</h2>
    <p>@Text.GetText("shell", "Home.StartText")</p>
    <a class="button-link" href="@FeaturedSlicePath">@Text.GetText("shell", "Home.StartAction")</a>
</section>

<section class="filter-bar" aria-label="@Text.GetText("shell", "Home.Families")">
    <span>@Text.GetText("shell", "Home.Families")</span>
    @foreach (string family in Families)
    {
        <button type="button"
                class="filter-button @(_selectedFamily == family ? "is-selected" : null)"
                aria-pressed="@(_selectedFamily == family)"
                @onclick="() => _selectedFamily = family">
            @FamilyLabel(family)
        </button>
    }
    <span class="filter-count">@VisiblePackages.Count() @Text.GetText("shell", "Home.FilterCount")</span>
</section>

<section class="package-grid" aria-label="@Text.GetText("shell", "Navigation.Home")">
@foreach (ShowcasePackageCatalogEntry package in VisiblePackages)
{
    IShowcaseSlice? slice = SliceCatalog.FindByPackageId(package.Id);
    ShowcaseImplementationStatus implementation = slice is null
        ? ShowcaseImplementationStatus.Planned
        : ShowcaseImplementationStatus.Available;
    <article class="package-card @(implementation == ShowcaseImplementationStatus.Available ? "available" : "planned")">
        <div class="card-meta">
            <span>@FamilyLabel(package.Family)</span>
            <span class="mono">@StateLabel(package.State)</span>
        </div>
        <h2><a href="/packages/@package.Slug">@package.Id</a></h2>
        <p>@PackageSummary(package)</p>
        <dl class="card-facts">
            <dt>@Text.GetText("shell", "Package.Sandbox")</dt>
            <dd>@Text.GetText("shell", slice?.Descriptor.RuntimeSandboxAvailable == true ? "Home.SandboxYes" : "Home.SandboxNo")</dd>
            @if (slice is not null)
            {
                <dt>@Text.GetText("shell", "Home.Version")</dt>
                <dd class="mono">@slice.Descriptor.Version</dd>
            }
        </dl>
        <div class="card-actions">
            <ShowcaseStateBadge Status="@implementation" Text="@ImplementationLabel(implementation)" />
            <a class="text-link" href="/packages/@package.Slug">@Text.GetText("shell", "Actions.Open")</a>
        </div>
    </article>
}
</section>

@code {
    private string _selectedFamily = "*";

    private IShowcaseSlice FeaturedSlice => SliceCatalog.Installed[0];
    private string FeaturedSlicePath => $"/packages/{FeaturedSlice.Descriptor.Slug}";
    private int PlannedCount => PackageCatalog.Packages.Count - SliceCatalog.Installed.Count;
    private string[] Families => ["*", .. PackageCatalog.Packages.Select(package => package.Family).Distinct(StringComparer.Ordinal).Order(StringComparer.Ordinal)];
    private IEnumerable<ShowcasePackageCatalogEntry> VisiblePackages => _selectedFamily == "*"
        ? PackageCatalog.Packages
        : PackageCatalog.Packages.Where(package => package.Family == _selectedFamily);

    private string PackageSummary(ShowcasePackageCatalogEntry package) =>
        Text.GetText("shell", $"Packages.{package.Id.Replace('.', '_')}.Summary");

    private string FamilyLabel(string family) => family switch
    {
        "*" => Text.GetText("shell", "Home.AllFamilies"),
        "Capability" => Text.GetText("shell", "Home.Capability"),
        "MaintainerDefaults" => Text.GetText("shell", "Home.MaintainerDefaults"),
        _ => family
    };

    private string StateLabel(string state) => state switch
    {
        "Active" => Text.GetText("shell", "Package.Active"),
        "Experimental" => Text.GetText("shell", "Package.Experimental"),
        _ => state
    };

    private string ImplementationLabel(ShowcaseImplementationStatus status) => status switch
    {
        ShowcaseImplementationStatus.Available => Text.GetText("shell", "Package.Available"),
        ShowcaseImplementationStatus.Failed => Text.GetText("shell", "Package.Failed"),
        _ => Text.GetText("shell", "Package.Planned")
    };
}
