<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Configuration"/>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection"/>
    <PackageReference Include="Microsoft.NET.Test.Sdk"/>
    <PackageReference Include="NUnit"/>
    <PackageReference Include="NUnit3TestAdapter"/>
    <PackageReference Include="Shouldly"/>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../../src/Modularity/Pocok.Modularity.csproj"/>
    <ProjectReference Include="../../Fixtures/Modularity.Contracts/Pocok.Modularity.FixtureContracts.csproj"/>
    <ProjectReference Include="../../Fixtures/Modularity.Plugin/Pocok.Modularity.FixturePlugin.csproj"
                      ReferenceOutputAssembly="false"/>
  </ItemGroup>

  <Target Name="CopyModularityPluginFixture" AfterTargets="Build">
    <ItemGroup>
      <_PluginFixture Include="$(MSBuildThisFileDirectory)../../Fixtures/Modularity.Plugin/bin/$(Configuration)/$(TargetFramework)/**/*"/>
    </ItemGroup>
    <Copy SourceFiles="@(_PluginFixture)"
          DestinationFiles="@(_PluginFixture->'$(OutDir)plugin-fixture/%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true"/>
  </Target>
</Project>
