root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{json,yml,yaml,props,targets,csproj,slnx,xml}]
indent_size = 2

[*.cs]
file_header_template = SPDX-License-Identifier: Apache-2.0\nCopyright 2026 Pocok contributors
csharp_style_namespace_declarations = file_scoped:warning
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion
dotnet_style_require_accessibility_modifiers = always:warning
dotnet_sort_system_directives_first = true

[*.{received,verified}.{json,txt,xml}]
insert_final_newline = false
trim_trailing_whitespace = false

[src/Primitives/Error.cs]
dotnet_diagnostic.CA1716.severity = none

[src/Primitives/ResultOfT.cs]
dotnet_diagnostic.CA1000.severity = none

[tests/Unit/Conversion.Tests/*.cs]
dotnet_diagnostic.CA1859.severity = none
dotnet_diagnostic.CA1861.severity = none
