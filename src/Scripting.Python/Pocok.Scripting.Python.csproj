<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageId>Pocok.Scripting.Python</PackageId>
    <MinVerVersionOverride Condition="'$(PocokScriptingPythonPackageVersion)' != ''">$(PocokScriptingPythonPackageVersion)</MinVerVersionOverride>
    <MinVerTagPrefix>scripting.python-v</MinVerTagPrefix>
    <MinVerMinimumMajorMinor>0.1</MinVerMinimumMajorMinor>
    <MinVerDefaultPreReleaseIdentifiers>alpha.1</MinVerDefaultPreReleaseIdentifiers>
    <Description>Isolated CPython 3.14 trusted-local adapter for Pocok.Scripting.</Description>
    <PackageTags>scripting;python;cpython;worker;validation</PackageTags>
    <IsPackable>true</IsPackable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="../Scripting/Pocok.Scripting.csproj"/>
    <None Include="Worker/pocok_worker.py" Pack="true" PackagePath="buildTransitive/Pocok.Scripting.Python.Worker/" />
    <None Include="buildTransitive/Pocok.Scripting.Python.targets" Pack="true" PackagePath="buildTransitive/" />
  </ItemGroup>
</Project>
