<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageId>Pocok.Subscriptions</PackageId>
    <PackageVersion Condition="'$(PocokSubscriptionsPackageVersion)' != ''">$(PocokSubscriptionsPackageVersion)</PackageVersion>
    <MinVerTagPrefix>subscriptions-v</MinVerTagPrefix>
    <MinVerMinimumMajorMinor>0.1</MinVerMinimumMajorMinor>
    <MinVerDefaultPreReleaseIdentifiers>alpha.1</MinVerDefaultPreReleaseIdentifiers>
    <Description>Product-neutral keyed subscriptions with typed filtering and mapping.</Description>
    <PackageTags>subscriptions;events;filtering;mapping;dispatch</PackageTags>
    <IsPackable>true</IsPackable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>
</Project>
