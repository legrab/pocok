<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageId>Pocok.Scripting</PackageId>
    <MinVerVersionOverride Condition="'$(PocokScriptingPackageVersion)' != ''">$(PocokScriptingPackageVersion)</MinVerVersionOverride>
    <MinVerTagPrefix>scripting-v</MinVerTagPrefix>
    <MinVerMinimumMajorMinor>0.1</MinVerMinimumMajorMinor>
    <MinVerDefaultPreReleaseIdentifiers>alpha.1</MinVerDefaultPreReleaseIdentifiers>
    <Description>Engine-neutral bounded script execution contracts, registry, imports, and structured diagnostics.</Description>
    <PackageTags>scripting;engines;imports;capabilities;validation</PackageTags>
    <IsPackable>true</IsPackable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="../Conversion/Pocok.Conversion.csproj"/>
  </ItemGroup>
</Project>
