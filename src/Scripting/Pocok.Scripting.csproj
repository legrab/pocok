<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageId>Pocok.Scripting</PackageId>
    <PackageVersion Condition="'$(PocokScriptingPackageVersion)' != ''">$(PocokScriptingPackageVersion)</PackageVersion>
    <MinVerTagPrefix>scripting-v</MinVerTagPrefix>
    <MinVerMinimumMajorMinor>0.1</MinVerMinimumMajorMinor>
    <MinVerDefaultPreReleaseIdentifiers>alpha.1</MinVerDefaultPreReleaseIdentifiers>
    <Description>Restricted JavaScript execution with neutral bindings, bounded imports, and structured diagnostics.</Description>
    <PackageTags>scripting;javascript;jint;imports;capabilities</PackageTags>
    <IsPackable>true</IsPackable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Jint"/>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../Conversion/Pocok.Conversion.csproj"/>
  </ItemGroup>
</Project>
