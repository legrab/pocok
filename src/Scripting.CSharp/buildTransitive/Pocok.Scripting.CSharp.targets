<Project>
  <ItemGroup>
    <_PocokCSharpWorker Include="$(MSBuildThisFileDirectory)Pocok.Scripting.CSharp.Worker/**/*" />
    <Content Include="@(_PocokCSharpWorker)"
             Link="Pocok.Scripting/CSharpWorker/%(RecursiveDir)%(Filename)%(Extension)"
             CopyToOutputDirectory="PreserveNewest"
             CopyToPublishDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
