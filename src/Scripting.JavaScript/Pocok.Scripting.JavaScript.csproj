<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageId>Pocok.Scripting.JavaScript</PackageId>
    <MinVerVersionOverride Condition="'$(PocokScriptingJavaScriptPackageVersion)' != ''">$(PocokScriptingJavaScriptPackageVersion)</MinVerVersionOverride>
    <MinVerTagPrefix>scripting.javascript-v</MinVerTagPrefix>
    <MinVerMinimumMajorMinor>0.1</MinVerMinimumMajorMinor>
    <MinVerDefaultPreReleaseIdentifiers>alpha.1</MinVerDefaultPreReleaseIdentifiers>
    <Description>Restricted Jint JavaScript adapter for Pocok.Scripting.</Description>
    <PackageTags>scripting;javascript;jint;validation</PackageTags>
    <IsPackable>true</IsPackable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Acornima"/>
    <PackageReference Include="Jint"/>
    <ProjectReference Include="../Scripting/Pocok.Scripting.csproj"/>
  </ItemGroup>
</Project>
