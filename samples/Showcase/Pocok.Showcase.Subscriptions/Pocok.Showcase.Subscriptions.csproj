<Project Sdk="Microsoft.NET.Sdk.Razor">
  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <AddRazorSupportForMvc>true</AddRazorSupportForMvc>
    <ShowcasePluginId>pocok.showcase.subscriptions</ShowcasePluginId>
  </PropertyGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App"/>
    <ProjectReference Include="../../../showcase/src/Pocok.Showcase.Contracts/Pocok.Showcase.Contracts.csproj"/>
    <ProjectReference Include="../../../showcase/src/Pocok.Showcase.Components/Pocok.Showcase.Components.csproj"/>
    <ProjectReference Include="../../../src/Subscriptions/Pocok.Subscriptions.csproj"/>
    <ProjectReference Include="../../../src/Modularity.Contracts/Pocok.Modularity.Contracts.csproj"/>
  </ItemGroup>
  <ItemGroup>
    <Content Update="pocok.module.json" CopyToOutputDirectory="PreserveNewest" CopyToPublishDirectory="PreserveNewest"/>
    <Content Update="Content/**/*.json" CopyToOutputDirectory="PreserveNewest" CopyToPublishDirectory="PreserveNewest"/>
  </ItemGroup>
  <Import Project="../../../showcase/Showcase.Plugin.targets"/>
</Project>
