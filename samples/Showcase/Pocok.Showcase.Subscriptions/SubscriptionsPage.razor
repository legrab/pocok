<div class="package-page">
    <ShowcasePackageHeader Descriptor="Context.Descriptor"
                           Text="Context.Text"
                           ImplementationStatusText="@T("Package.Status.Available")"/>

    <ShowcasePackageWorkbench>
        <Samples>
            <ShowcaseSamplePicker Title="@T("Sandbox.Samples")"
                                  Samples="Context.Samples"
                                  SelectedId="@_selectedId"
                                  SelectedIdChanged="SelectSampleAsync"
                                  Text="Context.Text"
                                  ResourceNamespace="subscriptions"/>
        </Samples>
        <Main>
            <ShowcaseSandboxFrame @key="_sampleRevision"
                                  Title="@T("Sandbox.Title")"
                                  Status="@T("Sandbox.Ready")">
                <div class="field-grid">
                    <div class="field">
                        <label for="recipe-mode">@T("Fields.Mode")</label>
                        <select id="recipe-mode" value="@_input.Mode" @onchange="SetModeAsync">
                            @foreach (var mode in SubscriptionsRecipeRenderer.Modes)
                            {
                                <option value="@mode">@mode</option>
                            }
                        </select>
                    </div>
                    <div class="field">
                        <label for="recipe-capacity">@T("Fields.Capacity")</label>
                        <input id="recipe-capacity"
                               type="number"
                               min="1"
                               max="1000"
                               value="@_input.Capacity"
                               @onchange="SetCapacityAsync"/>
                    </div>
                    <div class="field checkbox-field">
                        <label for="recipe-optional">@T("Fields.IncludeOptional")</label>
                        <input id="recipe-optional"
                               type="checkbox"
                               checked="@_input.IncludeOptional"
                               @onchange="SetOptionalAsync"/>
                    </div>
                    <div class="field checkbox-field">
                        <label for="recipe-lifecycle">@T("Fields.IncludeLifecycle")</label>
                        <input id="recipe-lifecycle"
                               type="checkbox"
                               checked="@_input.IncludeLifecycle"
                               @onchange="SetLifecycleAsync"/>
                    </div>
                </div>

                <div class="code-block">
                    <pre><code>@_preview</code></pre>
                </div>
            </ShowcaseSandboxFrame>
        </Main>
        <Guidance>
            <ShowcaseGuideView Guide="Context.Slice.Guide"
                               Text="Context.Text"
                               ResourceNamespace="subscriptions"
                               MoreLabel="@T("Guide.More")"/>
            <ShowcaseBoundariesPanel Title="@T("Boundaries.Title")">
                <ul class="compact-list">
                    <li>@T("Boundaries.Generated")</li>
                    <li>@T("Boundaries.NoExecution")</li>
                    <li>@T("Boundaries.Constrained")</li>
                    <li>@T("Boundaries.Ownership")</li>
                </ul>
            </ShowcaseBoundariesPanel>
            <ShowcaseSourcePanel Title="@T("Source.Title")"
                                 Body="@T("Source.Body")"
                                 Path="@Context.Descriptor.SourceDocumentationPath"/>
        </Guidance>
    </ShowcasePackageWorkbench>
</div>

@code {
    [Parameter][EditorRequired] public ShowcasePageContext Context { get; set; } = default!;

    private SubscriptionsInput _input = new();
    private string _selectedId = string.Empty;
    private string _preview = string.Empty;
    private long _sampleRevision;

    protected override void OnInitialized()
    {
        SelectSample(Context.Samples.Single(static sample => sample.IsDefault));
    }

    private string T(string key)
    {
        return Context.Text.GetText("subscriptions", key);
    }

    private Task SelectSampleAsync(string id)
    {
        SelectSample(Context.Samples.Single(sample => sample.Id == id));
        return Task.CompletedTask;
    }

    private void SelectSample(IShowcaseSample sample)
    {
        _selectedId = sample.Id;
        _input = (SubscriptionsInput)sample.CreateInput();
        Refresh();
        _sampleRevision = checked(_sampleRevision + 1);
    }

    private Task SetModeAsync(ChangeEventArgs args)
    {
        _input = _input with { Mode = args.Value?.ToString() ?? _input.Mode };
        Refresh();
        return Task.CompletedTask;
    }

    private Task SetCapacityAsync(ChangeEventArgs args)
    {
        if (int.TryParse(args.Value?.ToString(), out var value))
            _input = _input with { Capacity = Math.Clamp(value, 1, 1000) };
        Refresh();
        return Task.CompletedTask;
    }

    private Task SetOptionalAsync(ChangeEventArgs args)
    {
        _input = _input with { IncludeOptional = ReadBool(args) };
        Refresh();
        return Task.CompletedTask;
    }

    private Task SetLifecycleAsync(ChangeEventArgs args)
    {
        _input = _input with { IncludeLifecycle = ReadBool(args) };
        Refresh();
        return Task.CompletedTask;
    }

    private static bool ReadBool(ChangeEventArgs args)
    {
        return args.Value is true || string.Equals(
            args.Value?.ToString(),
            "true",
            StringComparison.OrdinalIgnoreCase);
    }

    private void Refresh()
    {
        _preview = SubscriptionsRecipeRenderer.Render(_input);
    }

}
