<div class="field">
    <label for="script-engine">@T("Fields.Engine")</label>
    <select id="script-engine" value="@Value.EngineId" @onchange="ChangeEngineAsync">
        @foreach (var descriptor in Engines)
        {
            <option value="@descriptor.Id.Value">
                @descriptor.Language @(!descriptor.IsAvailable ? $"— {descriptor.UnavailableCode}" : null)
            </option>
        }
    </select>
    @if (Selected is { IsAvailable: false })
    {
        <small role="status">@Selected.UnavailableMessage</small>
    }
</div>

<ShowcaseMonacoEditor @ref="_monaco"
                      Label="@T("Sandbox.CodeLabel")"
                      Language="@Value.EngineId"
                      Value="@Value.Source"
                      ValueChanged="SetSourceAsync"
                      ResetRevision="@ResetRevision"
                      Completions="@Completions"
                      FallbackDiagnostic="@T("Sandbox.EditorFallback")"/>

<small class="@(SourceLimitExceeded ? "diagnostic warning" : null)"
       role="@(SourceLimitExceeded ? "status" : null)">
    @SourceLengthText
</small>

<div class="field-grid scripting-options">
    <div class="field checkbox-field">
        <label for="expect-result">@T("Fields.ExpectResult")</label>
        <input id="expect-result"
               type="checkbox"
               checked="@Value.ExpectResult"
               @onchange="args => UpdateAsync(Value with { ExpectResult = ReadValue(args, Value.ExpectResult) })"/>
    </div>
    <div class="field">
        <label for="timeout">@T("Fields.Timeout")</label>
        <input id="timeout"
               type="number"
               min="50"
               max="@MaximumTimeoutMilliseconds"
               step="50"
               value="@Value.TimeoutMilliseconds"
               @onchange="args => UpdateAsync(Value with { TimeoutMilliseconds = Math.Clamp(ReadValue(args, Value.TimeoutMilliseconds), 50, MaximumTimeoutMilliseconds) })"/>
    </div>
    @if (Selected?.Capabilities.EnforcesStatementLimit == true)
    {
        <div class="field">
            <label for="statements">@T("Fields.MaxStatements")</label>
            <input id="statements"
                   type="number"
                   min="100"
                   max="@MaximumStatements"
                   value="@Value.MaxStatements"
                   @onchange="args => UpdateAsync(Value with { MaxStatements = Math.Clamp(ReadValue(args, Value.MaxStatements ?? MaximumStatements), 100, MaximumStatements) })"/>
        </div>
    }
    @if (Selected?.Capabilities.EnforcesRecursionLimit == true)
    {
        <div class="field">
            <label for="recursion">@T("Fields.MaxRecursion")</label>
            <input id="recursion"
                   type="number"
                   min="8"
                   max="@MaximumRecursionDepth"
                   value="@Value.MaxRecursionDepth"
                   @onchange="args => UpdateAsync(Value with { MaxRecursionDepth = Math.Clamp(ReadValue(args, Value.MaxRecursionDepth ?? MaximumRecursionDepth), 8, MaximumRecursionDepth) })"/>
        </div>
    }
    @if (Selected?.Capabilities.EnforcesMemoryLimit == true)
    {
        <div class="field">
            <label for="memory">@T("Fields.MaxMemory")</label>
            <input id="memory"
                   type="number"
                   min="4"
                   max="@MaximumMemoryMegabytes"
                   value="@Value.MaxMemoryMegabytes"
                   @onchange="args => UpdateAsync(Value with { MaxMemoryMegabytes = Math.Clamp(ReadValue(args, Value.MaxMemoryMegabytes ?? MaximumMemoryMegabytes), 4, MaximumMemoryMegabytes) })"/>
        </div>
    }
</div>
